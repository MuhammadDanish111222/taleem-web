NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

SUPABASE_URL=

# DEEPSEEK_API_KEY= (service-only, not used here yet)

RAILWAY_AI_SERVICE_URL=http://localhost:8000

# Content Upload Limits
CONTENT_UPLOAD_MAX_MULTIPART_BYTES=52428800
CONTENT_UPLOAD_MAX_PDF_BYTES=52428800
CONTENT_UPLOAD_MAX_PDF_PAGES=500
CONTENT_UPLOAD_MAX_FIELDS=20
CONTENT_UPLOAD_MAX_FIELD_BYTES=10240
CONTENT_UPLOAD_MAX_FILENAME_BYTES=255
CONTENT_UPLOAD_PARSE_TIMEOUT_MS=15000
CONTENT_UPLOAD_IDEMPOTENCY_SECRET=placeholder-secret-change-in-production
CONTENT_UPLOAD_TEMP_DIR=/tmp
CONTENT_UPLOAD_CLEANUP_BATCH_SIZE=10
CONTENT_UPLOAD_MAX_CLEANUP_ATTEMPTS=5

# Google Drive Storage Configuration
# Auth Modes: "oauth_user" (personal My Drive), "shared_drive" (Workspace Shared Drive), or "delegated" (Workspace Delegation)
GOOGLE_DRIVE_AUTH_MODE=oauth_user

# OAuth User Mode Credentials (required for oauth_user mode; run `npm run drive:authorize` to obtain)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_CONTENT_FOLDER_ID=

# Service Account Credentials (required for shared_drive or delegated mode)
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_SHARED_DRIVE_ID=
GOOGLE_DRIVE_DELEGATED_USER=

# Optional Drive API Settings
GOOGLE_DRIVE_REQUEST_TIMEOUT_MS=15000
GOOGLE_DRIVE_MAX_ATTEMPTS=3
