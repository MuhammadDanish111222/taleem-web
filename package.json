{
  "name": "taleem-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run --no-file-parallelism",
    "test:unit": "vitest run --no-file-parallelism tests/auth tests/drive tests/internalAuth tests/search/normalize.test.ts tests/search/tokenize.test.ts",
    "test:bff:http": "vitest run --no-file-parallelism tests/bffToFastapiHttpIntegration.test.ts",
    "test:rules": "npx -y firebase-tools emulators:exec --only firestore \"vitest run --no-file-parallelism tests/firestore tests/resources tests/search/resourceSearch.emulator.test.ts tests/search/backfill.emulator.test.ts tests/firestore.rules.test.ts scripts/manual-test-phase2a.test.ts scripts/manual-test-phase2b.test.ts\"",
    "test:phase2a": "npm run test:unit && npm run test:rules",
    "test:drive:smoke": "vitest run tests/storage/smoke.test.ts",
    "typecheck": "tsc --noEmit",
    "scan:bundle": "node scripts/scan-bundle.js",
    "drive:authorize": "tsx scripts/authorizeDrive.ts",
    "search:backfill": "tsx scripts/backfill-resource-search.ts"
  },
  "dependencies": {
    "@googleapis/drive": "^20.2.0",
    "busboy": "^1.6.0",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "googleapis": "^173.0.0",
    "next": "^16.2.10",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^3.23.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/busboy": "^1.5.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^8",
    "eslint-config-next": "15.1.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
