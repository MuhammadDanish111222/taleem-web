rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Site settings: universally public
    match /site_settings/default {
      allow read: if true;
    }
    
    // Academy settings: public only if visible is true
    match /academy_settings/default {
      allow read: if resource.data.visible == true;
    }
    
    // Public Catalogue
    match /boards/{boardId} {
      allow read: if resource.data.active == true;
      
      match /classes/{classId} {
        allow read: if resource.data.active == true
                    && get(/databases/$(database)/documents/boards/$(boardId)).data.active == true;
                    
        match /subjects/{subjectId} {
          allow read: if resource.data.active == true
                      && get(/databases/$(database)/documents/boards/$(boardId)/classes/$(classId)).data.active == true
                      && get(/databases/$(database)/documents/boards/$(boardId)).data.active == true;
                      
          match /chapters/{chapterId} {
            allow read: if resource.data.active == true
                        && get(/databases/$(database)/documents/boards/$(boardId)/classes/$(classId)/subjects/$(subjectId)).data.active == true
                        && get(/databases/$(database)/documents/boards/$(boardId)/classes/$(classId)).data.active == true
                        && get(/databases/$(database)/documents/boards/$(boardId)).data.active == true;
          }
        }
      }
    }
    // Resources: Public if published and hierarchy is active
    match /resources/{resourceId} {
      allow read: if resource.data.status == "published"
                  && get(/databases/$(database)/documents/boards/$(resource.data.boardId)).data.active == true
                  && get(/databases/$(database)/documents/boards/$(resource.data.boardId)/classes/$(resource.data.classId)).data.active == true
                  && get(/databases/$(database)/documents/boards/$(resource.data.boardId)/classes/$(resource.data.classId)/subjects/$(resource.data.subjectId)).data.active == true
                  && (resource.data.chapterId == null || get(/databases/$(database)/documents/boards/$(resource.data.boardId)/classes/$(resource.data.classId)/subjects/$(resource.data.subjectId)/chapters/$(resource.data.chapterId)).data.active == true);
      
      match /versions/{versionId} {
        allow read, write: if false;
      }
    }

    match /admin_audit_logs/{logId} {
      allow read, write: if false;
    }
    
    // Default deny all client writes (Admin SDK bypasses this)
    // Default deny any reads not explicitly allowed above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
